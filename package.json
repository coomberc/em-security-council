{
  "name": "em-security-council",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "bash scripts/db-down.sh",
    "db:destroy": "bash scripts/db-down.sh --destroy",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:reset": "npx prisma migrate reset",
    "db:setup": "npm run db:up && npm run db:migrate && npm run db:seed",
    "db:fresh": "npm run db:up && npx prisma migrate reset --force && npx prisma generate",
    "db:studio": "npx prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.991.0",
    "@hookform/resolvers": "^4.1.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@slack/web-api": "^7.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-markdown": "10.1.0",
    "recharts": "3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "jiti": "^2.6.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
